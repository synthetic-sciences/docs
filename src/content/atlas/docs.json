{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Atlas",
  "colors": {
    "primary": "#2f6f54",
    "light": "#2f6f54",
    "dark": "#9bd6b4"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "index",
              "quickstart",
              "first-graph",
              "source-to-graph",
              "agent-onboarding"
            ]
          },
          {
            "group": "Primitives",
            "pages": [
              "graph",
              "sources-search",
              "artifacts-files",
              "exports-imports"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "auth-config",
              "cli-runtime",
              "skills",
              "safety"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI reference",
            "pages": [
              "feature-map",
              "commands"
            ]
          },
          {
            "group": "HTTP API",
            "pages": [
              "api-reference/introduction",
              "api-reference/atlas-rest"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.syntheticsciences.ai/atlas",
          "icon": "square-arrow-up-right"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/synthetic-sciences",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Atlas",
        "href": "https://app.syntheticsciences.ai/atlas"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.syntheticsciences.ai/atlas"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthetic-sciences"
    }
  }
}
