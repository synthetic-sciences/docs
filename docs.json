{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "synsci",
  "description": "Synthetic Sciences documentation. Thesis is a graph-based research workspace. Synsci CLI is a terminal agent for scientific work.",
  "colors": {
    "primary": "#06b6d4",
    "light": "#67e8f9",
    "dark": "#0e7490"
  },
  "logo": {
    "light": "/logo/synsc-logo.png",
    "dark": "/logo/synsc-logo.png"
  },
  "favicon": "/logo/synsc-logo.png",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 600
    },
    "body": {
      "family": "Space Grotesk",
      "weight": 400
    }
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#0a0a0b"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://cli.syntheticsciences.ai"
      },
      {
        "label": "Thesis",
        "href": "https://thesis.syntheticsciences.ai"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Thesis",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "web-app"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/research-graph",
              "concepts/research-log",
              "concepts/knowledge-layer",
              "concepts/agent-harness",
              "concepts/compute"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/organize-research",
              "guides/design-experiment",
              "guides/run-sub-agents",
              "guides/search-synthesize",
              "guides/export"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/compute-providers"
            ]
          }
        ]
      },
      {
        "tab": "Thesis MCP",
        "groups": [
          {
            "group": "Setup",
            "pages": [
              "mcp/quickstart",
              "mcp/supported-hosts",
              "mcp/authentication"
            ]
          },
          {
            "group": "MCP Tools",
            "pages": [
              "mcp/tools-overview",
              "mcp/tools-nodes",
              "mcp/tools-knowledge",
              "mcp/tools-compute",
              "mcp/tools-export"
            ]
          }
        ]
      },
      {
        "tab": "Synsci CLI",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "cli/introduction",
              "cli/installation",
              "cli/quickstart",
              "cli/web"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "cli/agents"
            ]
          },
          {
            "group": "Research modes",
            "pages": [
              "cli/research/research",
              "cli/research/physics",
              "cli/research/chemistry",
              "cli/research/biology",
              "cli/research/flywheel"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "cli/credentials",
              "cli/credits",
              "cli/dashboard",
              "cli/desktop"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "cli/mcp"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "cli/commands",
              "cli/security",
              "cli/comparison"
            ]
          }
        ]
      }
    ]
  }
}
