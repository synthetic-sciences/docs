{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Synthetic Sciences",
  "description": "Atlas is a graph-based research workspace. Synci CLI is a terminal agent for scientific work, with research modes for physics, chemistry, biology, general research, and the model flywheel.",
  "colors": {
    "primary": "#0f172a",
    "light": "#475569",
    "dark": "#0f172a"
  },
  "logo": {
    "light": "/logo/wordmark.png",
    "dark": "/logo/wordmark.png"
  },
  "favicon": "/logo/synsc-mark.png",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Computer Modern",
      "weight": 700,
      "format": "woff2",
      "source": "https://docs.syntheticsciences.ai/fonts/cmc/cmunobx.woff2"
    },
    "body": {
      "family": "Computer Modern",
      "weight": 400,
      "format": "woff2",
      "source": "https://docs.syntheticsciences.ai/fonts/cmc/cmunorm.woff2"
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#fafbfc",
      "dark": "#0a0a0b"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.syntheticsciences.ai"
    }
  },
  "navigation": {
    "versions": [
      {
        "version": "Atlas @synsci/atlas@0.5.11",
        "default": true,
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Start",
                "pages": [
                  "introduction",
                  "quickstart",
                  "web-app"
                ]
              },
              {
                "group": "Concepts",
                "pages": [
                  "concepts/research-graph",
                  "concepts/research-log",
                  "concepts/knowledge-layer",
                  "concepts/agent-harness",
                  "concepts/compute"
                ]
              },
              {
                "group": "Context",
                "pages": [
                  "context/delphi"
                ]
              },
              {
                "group": "Guides",
                "pages": [
                  "guides/organize-research",
                  "guides/design-experiment",
                  "guides/run-sub-agents",
                  "guides/search-synthesize",
                  "guides/export"
                ]
              }
            ]
          }
        ]
      },
      {
        "version": "CLI",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Start",
                "pages": [
                  "cli/introduction",
                  "cli/installation",
                  "cli/quickstart",
                  "cli/web"
                ]
              },
              {
                "group": "Agents",
                "pages": [
                  "cli/agents"
                ]
              },
              {
                "group": "Research modes",
                "pages": [
                  "cli/research/research",
                  "cli/research/physics",
                  "cli/research/chemistry",
                  "cli/research/biology",
                  "cli/research/write",
                  "cli/research/flywheel"
                ]
              },
              {
                "group": "Operations",
                "pages": [
                  "cli/credentials",
                  "cli/credits",
                  "cli/dashboard",
                  "cli/desktop"
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "cli/commands",
                  "cli/security",
                  "cli/comparison"
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
